{
  "version": 8,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28
  },
  "include": [
    "presets/common.json",
    "presets/flags.json",
    "presets/platforms.json",
    "presets/tools.json"
  ],
  "configurePresets": [
    {
      "name": "common",
      "generator": "Ninja Multi-Config",
      "hidden": true,
      "inherits": [
        "std",
        "vcpkg",
        "ccache",
        "shared-bin-dir"
      ]
    },
    {
      "name": "x64-windows-msvc",
      "inherits": [
        "common",
        "platform-x64-windows",
        "flags-msvc"
      ]
    },
    {
      "name": "x64-linux-gcc",
      "inherits": [
        "common",
        "platform-x64-linux",
        "flags-gcc"
      ]
    },
    {
      "name": "wasm32-emscripten-clang",
      "inherits": [
        "common",
        "platform-wasm32-emscripten"
      ]
    }
  ],
  "buildPresets": [
    {
      "name": "x64-linux-gcc-Debug",
      "configurePreset": "x64-linux-gcc",
      "configuration": "Debug",
      "jobs": 12
    },
    {
      "name": "wasm32-emscripten-clang-Debug",
      "configurePreset": "wasm32-emscripten-clang",
      "configuration": "Debug",
      "jobs": 12
    },
    {
      "name": "x64-linux-gcc-Release",
      "configurePreset": "x64-linux-gcc",
      "configuration": "Release",
      "jobs": 12
    },
    {
      "name": "wasm32-emscripten-clang-Release",
      "configurePreset": "wasm32-emscripten-clang",
      "configuration": "Release",
      "jobs": 12
    }
  ],
  "testPresets": [
    {
      "name": "wasm32-emscripten-clang-Debug",
      "configurePreset": "wasm32-emscripten-clang",
      "configuration": "Debug",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "wasm32-emscripten-clang-Release",
      "configurePreset": "wasm32-emscripten-clang",
      "configuration": "Release",
      "output": {"outputOnFailure": true}
    }
  ],
  "packagePresets": [
    {
      "name": "wasm32-emscripten-clang-Debug",
      "configurePreset": "wasm32-emscripten-clang",
      "configurations": ["Debug"],
      "generators": [
        "ZIP"
      ]
    },
    {
      "name": "wasm32-emscripten-clang-Release",
      "configurePreset": "wasm32-emscripten-clang",
      "configurations": ["Release"],
      "generators": [
        "ZIP"
      ]
    }
  ]
}
